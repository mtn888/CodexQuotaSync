<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF2F5F3"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#FF173F35"
            android:textSize="27sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_detail_connection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/status_loading"
            android:textColor="#FF356958"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_detail_source"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="#FF6C7B75"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="112dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/detail_card_background"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/short_quota" android:textColor="#FF66756F" android:textSize="12sp" />
                <TextView android:id="@+id/text_detail_short_quota" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/not_available" android:textColor="#FF173F35" android:textSize="34sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="112dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/detail_card_background"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/weekly_quota" android:textColor="#FF66756F" android:textSize="12sp" />
                <TextView android:id="@+id/text_detail_weekly_quota" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/not_available" android:textColor="#FF173F35" android:textSize="34sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/text_detail_reset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/detail_card_background"
            android:padding="16dp"
            android:text="@string/next_reset_empty"
            android:textColor="#FF31473F"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="92dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/detail_card_background"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/executing" android:textColor="#FF66756F" android:textSize="12sp" />
                <TextView android:id="@+id/text_detail_executing" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/zero" android:textColor="#FF176B45" android:textSize="29sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="92dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/detail_card_background"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/pending" android:textColor="#FF66756F" android:textSize="12sp" />
                <TextView android:id="@+id/text_detail_pending" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/zero" android:textColor="#FF9A7410" android:textSize="29sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/text_detail_updated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="3dp"
            android:text="@string/no_cached_data"
            android:textColor="#FF66756F"
            android:textSize="13sp" />

        <ProgressBar
            android:id="@+id/refresh_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="16dp"
            android:indeterminate="true"
            android:visibility="gone" />

        <Button
            android:id="@+id/button_detail_refresh"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:text="@string/refresh_now"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/button_open_settings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="@string/server_settings"
            android:textAllCaps="false" />
    </LinearLayout>
</ScrollView>
